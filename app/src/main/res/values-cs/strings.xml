    <!-- Help -->
    <string name="help_title">Nápověda</string>
    <string name="help_section_faq">Často kladené otázky</string>
    <string name="help_faq_collapse">Sbalit</string>
    <string name="help_faq_expand">Rozbalit</string>
    <string name="help_section_contact">Kontakt</string>
    <string name="help_contact_send_email">Napsat e-mail</string>
    <string name="help_contact_email">hello@codewhiskers.app</string>
    <string name="help_faq1_q">Jak vytvořit novou akci?</string>
    <string name="help_faq1_a">Klepni na tlačítko + na spodní liště a vyplň název, datum a popis akce. Po vytvoření můžeš přidávat moduly jako hlasování, výdaje nebo spolujízdu.</string>
    <string name="help_faq2_q">Jak pozvat přátele?</string>
    <string name="help_faq2_a">V nastavení akce najdeš odkaz pro sdílení. Můžeš ho zkopírovat nebo rovnou sdílet přes libovolnou aplikaci. Pozvaní se připojí jedním klepnutím.</string>
    <string name="help_faq3_q">Jak fungují výdaje?</string>
    <string name="help_faq3_a">V modulu Výdaje přidáš výdaj a zadáš částku. Můžeš vybrat, kdo platil a mezi koho se výdaj rozdělí. Aplikace automaticky vypočítá vyrovnání.</string>
    <string name="help_faq4_q">Jak funguje hlasování?</string>
    <string name="help_faq4_a">V modulu Hlasování vytvoříš anketu s možnostmi a ostatní účastníci mohou hlasovat. Výsledky se zobrazují v reálném čase.</string>
    <string name="help_faq5_q">Jak změnit nastavení akce?</string>
    <string name="help_faq5_a">Na dashboardu akce klepni na Nastavení. Zde můžeš upravit název, popis, zabezpečení, rozpočet a další možnosti.</string>
    <string name="help_faq6_q">Jak funguje spolujízda?</string>
    <string name="help_faq6_a">V modulu Spolujízda můžeš nabídnout místa ve svém autě nebo se přidat ke spolujízdě. Každý vidí, kdo řídí a kolik míst je volných.</string>
    <string name="help_faq7_q">Jak fungují pokoje?</string>
    <string name="help_faq7_a">V modulu Pokoje kdokoliv vytvoří pokoje s kapacitou. Klepnutím na pokoj se do něj přidáš — můžeš být jen v jednom pokoji najednou. Dalším klepnutím pokoj opustíš.</string>
    <string name="help_faq8_q">K čemu je balicí seznam?</string>
    <string name="help_faq8_a">Balicí seznam je sdílený seznam věcí potřebných na akci. Kdokoliv může přidat položku a označit, co je už zajištěné, aby se na nic nezapomnělo.</string>
    <string name="help_faq9_q">Jaký je rozdíl mezi Free a Pro?</string>
    <string name="help_faq9_a">Free plán umožňuje až 2 akce s max 8 účastníky a 1 anketou. Pro odemkne až 5 akcí, 100 účastníků, neomezené ankety, export výdajů a odstraní reklamy.</string>
    <string name="help_faq10_q">Jak zabezpečit akci PINem?</string>
    <string name="help_faq10_a">V nastavení akce zapni ochranu PINem a nastav kód. Každý, kdo se bude chtít připojit, bude muset nejdříve zadat PIN.</string>

